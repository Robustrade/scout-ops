{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["endpoint", "alerts"],
  "properties": {
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "alerts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "threshold_ms"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["latency"]
          },
          "threshold_ms": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "severity": {
            "type": "string"
          },
          "eval_interval": {
            "type": "string",
            "pattern": "^[0-9]+[smh]$"
          },
          "lookback": {
            "type": "string",
            "pattern": "^[0-9]+[smh]$"
          },
          "table": {
            "type": "string"
          },
          "folderUid": {
            "type": "string"
          },
          "contactPoint": {
            "type": "string"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "query_template": {
            "type": "string"
          }
        }
      }
    }
  }
}
